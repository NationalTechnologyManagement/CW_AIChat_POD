# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
DEFAULT_MODEL=anthropic/claude-sonnet-4

# ConnectWise Manage
# Get CW_COMPANY_ID and CW_ENTRY_POINT from: https://api-na.myconnectwise.net/login/companyinfo/YOUR_COMPANY
CW_COMPANY_ID=yourcompanyid
CW_AUTH_COMPANY_ID=shortname
CW_API_URL=https://api-na.myconnectwise.net
CW_ENTRY_POINT=v2025_1
CW_PUBLIC_KEY=xxxxxxxxxxxxxxxx
CW_PRIVATE_KEY=xxxxxxxxxxxxxxxx
CW_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App
APP_URL=https://your-app.up.railway.app
POD_SECRET=change-me-to-a-long-random-string
CW_MANAGE_URL=https://na.myconnectwise.net
